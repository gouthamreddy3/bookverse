# Copy this file to .env.local and fill in real values.
# Nothing here is wired up yet — added ahead of the Prisma/Auth.js milestones.

# Database (Prisma + PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/bookverse"

# Auth.js
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Book data
# Open Library requires no API key.
# Google Books is a fallback only; a key raises its rate limit.
GOOGLE_BOOKS_API_KEY=""
