# Copy this file to .env.local and fill in real values.

# Database (Neon Postgres)
# DATABASE_URL: pooled connection (PgBouncer) — used by the app at runtime.
# DIRECT_URL: unpooled connection — used by Prisma Migrate only.
# Get both from your Neon project's Connection Details panel.
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/bookverse?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-example.region.aws.neon.tech/bookverse?sslmode=require"

# Auth.js — not wired up yet
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Book data
# Open Library requires no API key.
# Google Books is a fallback only; a key raises its rate limit.
GOOGLE_BOOKS_API_KEY=""
